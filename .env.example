[TEMPLATE]
# Cles API pour les providers IA
# Copie ce fichier en .env et remplis les cles que tu utilises
#
# --- Rotation multi-cle ---
# Chaque provider peut avoir plusieurs cles pour la rotation LRU.
# La cle de base (sans suffixe) est la premiere utilisee.
# Les cles supplementaires utilisent le suffixe _1, _2, etc.
# En cas d erreur 429 (rate limit), le systeme passe automatiquement
# a la cle suivante et fait Round-Robin.
#
# Exemple avec 3 cles OpenRouter :
#   OPENROUTER_API_KEY=sk-or-key-1
#   OPENROUTER_API_KEY_1=sk-or-key-2
#   OPENROUTER_API_KEY_2=sk-or-key-3

# --- Providers en ligne ---
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=

GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=

GROQ_API_KEY=
GROQ_API_KEY_1=

MISTRAL_API_KEY=
MISTRAL_API_KEY_1=

OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_API_KEY_1=
